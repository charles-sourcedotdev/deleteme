<?xml version="1.0" encoding="UTF-8"?>
<manifest>

  <remote name="github" fetch="https://github.com/" />

  <default remote="github" sync-j="4" />

  <!--
    External C/C++ libraries.  Chosen because:
      - each has a self-contained CMakeLists.txt (no inter-dependencies)
      - collectively produce ~300 translation units → good CAS exercise
      - pinned to stable tags for reproducible builds
  -->
  <project name="madler/zlib"
           path="external/zlib"
           revision="refs/tags/v1.3.1" />

  <project name="abseil/abseil-cpp"
           path="external/abseil-cpp"
           revision="refs/tags/20240722.0" />

  <project name="google/googletest"
           path="external/googletest"
           revision="refs/tags/v1.15.2" />

</manifest>
